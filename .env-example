# db
DB__HOST=localhost
DB__PORT=5432
DB__USER=postgres
DB__PASSWORD=postgres
DB__NAME=postgres

# api auth
AUTH__API_KEY=local-api-key

# rabbitmq
RABBIT__USER=guest
RABBIT__PASSWORD=guest
RABBIT__HOST=localhost
RABBIT__PORT=5672
RABBIT__VIRTUAL_HOST=/
RABBIT__EXCHANGE_NAME=payments.events
RABBIT__NEW_PAYMENTS_QUEUE_NAME=payments.new
RABBIT__NEW_PAYMENTS_ROUTING_KEY=payments.new
RABBIT__NEW_PAYMENTS_DELIVERY_LIMIT=3
RABBIT__DEAD_LETTER_EXCHANGE_NAME=payments.events.dlx
RABBIT__DEAD_LETTER_QUEUE_NAME=payments.new.dlq
RABBIT__DEAD_LETTER_ROUTING_KEY=payments.new.dlq

# outbox
OUTBOX__ENABLED=true
OUTBOX__BATCH_SIZE=100
OUTBOX__POLL_INTERVAL_SECONDS=1.0

# webhook
WEBHOOK__TIMEOUT_SECONDS=5.0
WEBHOOK__MAX_ATTEMPTS=3
WEBHOOK__RETRY_BACKOFF_BASE_SECONDS=1.0
